# EasyPanel → sass-botflow → frontend → Environment (copy all)
# Available at build-time AND run-time on EasyPanel GitHub Source deploys.

CLERK_SECRET_KEY=sk_live_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
JWT_SECRET=<same as api.botflow.ink backend JWT_SECRET>
NEXT_PUBLIC_APP_URL=https://www.botflow.ink
NEXT_PUBLIC_API_URL=https://api.botflow.ink
# Server-only override (recommended — prevents misconfigured public URL loops)
BACKEND_API_URL=https://api.botflow.ink
NEXT_PUBLIC_META_APP_ID=1811541566932500
NEXT_PUBLIC_META_EMBEDDED_SIGNUP_CONFIG_ID=1353028573456188
PORT=3000

# Optional build stamp (EasyPanel GitHub builds — Dockerfile reads git SHA automatically)
# GITHUB_SHA=
# COMMIT_SHA=

# DO NOT add to frontend:
# DATABASE_URL
# META_APP_SECRET (backend only)
# INTEGRATION_ENCRYPTION_KEY
