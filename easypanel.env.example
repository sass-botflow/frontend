# EasyPanel → sass-botflow → frontend → Environment (copy all)

CLERK_SECRET_KEY=sk_live_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
JWT_SECRET=<same as api.botflow.ink backend JWT_SECRET>
NEXT_PUBLIC_APP_URL=https://www.botflow.ink
NEXT_PUBLIC_API_URL=https://api.botflow.ink
BACKEND_API_URL=https://api.botflow.ink
PORT=3000

# WhatsApp QR fallback (until backend redeploys) — server-side only
EVOLUTION_API_URL=https://evolution.api.botflow.ink
EVOLUTION_API_KEY=<same as Evolution AUTHENTICATION_API_KEY>
EVOLUTION_WEBHOOK_URL=https://api.botflow.ink/webhooks/evolution

# DO NOT add to frontend:
# DATABASE_URL
# INTEGRATION_ENCRYPTION_KEY
