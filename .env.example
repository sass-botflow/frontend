# App (production: https://www.botflow.ink)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API (production: https://api.botflow.ink)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Clerk (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Must match the NestJS backend JWT_SECRET exactly (server-only)
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars

# Meta Embedded Signup (public IDs — required for /dashboard/channels WhatsApp connect)
NEXT_PUBLIC_META_APP_ID=
NEXT_PUBLIC_META_EMBEDDED_SIGNUP_CONFIG_ID=

# Optional: Clerk JWT template if backend validates Clerk-issued JWTs directly
# CLERK_BACKEND_JWT_TEMPLATE=botflow-api

# Optional verbose BFF auth logging
# BACKEND_AUTH_DEBUG=true

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding
NEXT_PUBLIC_CLERK_AFTER_SIGN_OUT_URL=/en
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/onboarding

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
