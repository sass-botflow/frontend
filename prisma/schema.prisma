generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Integration {
  id              String    @id @default(cuid())
  userId          String
  platform        String
  externalId      String?
  accessToken     String?
  refreshToken    String?
  metaBusinessId  String?
  phoneNumberId   String?
  phoneNumber     String?
  phoneStatus     String?
  businessName    String?
  connectedAt     DateTime?
  isConnected     Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([userId, platform])
  @@index([userId])
  @@index([phoneNumberId])
}

model Affiliate {
  id          String   @id @default(cuid())
  userId      String   @unique
  code        String   @unique
  status      String   @default("active")
  payoutEmail String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  referrals Referral[]
  earnings  AffiliateEarning[]

  @@index([code])
}

model Referral {
  id             String    @id @default(cuid())
  affiliateId    String
  affiliate      Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  referredUserId String?   @unique
  status         String    @default("pending")
  planId         String?
  planName       String?
  monthlyValue   Float     @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([affiliateId])
  @@index([status])
}

model AffiliateEarning {
  id          String    @id @default(cuid())
  affiliateId String
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  amount      Float
  type        String    @default("commission")
  status      String    @default("pending")
  period      String?
  description String?
  createdAt   DateTime  @default(now())

  @@index([affiliateId])
  @@index([status])
}
