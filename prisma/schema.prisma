generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Integration {
  id           String   @id @default(cuid())
  userId       String
  platform     String
  externalId   String?
  accessToken  String?
  refreshToken String?
  isConnected  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, platform])
  @@index([userId])
}
